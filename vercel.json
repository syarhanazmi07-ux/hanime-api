{
  "version": 2,
  "functions": {
    "api/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    { "src": "/api/recent", "dest": "/api/recent.js" },
    { "src": "/api/trending", "dest": "/api/trending.js" },
    { "src": "/api/search", "dest": "/api/search.js" },
    { "src": "/api/info", "dest": "/api/info.js" },
    { "src": "/api/streams", "dest": "/api/streams.js" },
    { "src": "/", "dest": "/api/recent.js" }
  ]
}
